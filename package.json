{
  "name": "codeview",
  "version": "1.0.0",
  "description": "Local codebase intelligence server for coding agents — type-aware repo maps + semantic search via Ollama",
  "type": "module",
  "license": "MIT",
  "bin": {
    "codeview": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "prepublishOnly": "bun run build && bun test && bun run typecheck",
    "dev": "bun run --watch src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ts-morph": "^24",
    "sqlite-vec": "^0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ramankarki/codeview"
  },
  "keywords": [
    "codebase",
    "intelligence",
    "embedding",
    "semantic-search",
    "repo-map",
    "typescript",
    "coding-agent",
    "llm",
    "ollama"
  ]
}
